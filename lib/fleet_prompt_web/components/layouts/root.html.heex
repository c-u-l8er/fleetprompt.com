<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>FleetPrompt — Agent Marketplace</title>
    <style>
      :root {
        --color-bg: #0a0a0f;
        --color-surface: #12121a;
        --color-border: #1e1e2e;
        --color-text: #e4e4ef;
        --color-text-muted: #8888a0;
        --color-accent: #6366f1;
        --color-green: #22c55e;
        --color-blue: #3b82f6;
        --color-yellow: #eab308;
        --color-orange: #f97316;
        --color-red: #ef4444;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
      }
      .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
      nav {
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 0;
      }
      nav .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      nav .logo {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-accent);
        text-decoration: none;
      }
      nav .nav-links { display: flex; gap: 1.5rem; }
      nav .nav-links a {
        color: var(--color-text-muted);
        text-decoration: none;
        font-size: 0.875rem;
      }
      nav .nav-links a:hover { color: var(--color-text); }
      main { padding: 2rem 0; }
      .trust-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.625rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
      }
      .trust-green { background: #052e16; color: var(--color-green); }
      .trust-blue { background: #0c1a33; color: var(--color-blue); }
      .trust-yellow { background: #2d2305; color: var(--color-yellow); }
      .trust-orange { background: #2d1605; color: var(--color-orange); }
      .trust-red { background: #2d0505; color: var(--color-red); }
      .trust-gray { background: #1e1e2e; color: var(--color-text-muted); }
      .status-pill {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        border-radius: 9999px;
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .status-published { background: #052e16; color: var(--color-green); }
      .status-draft { background: #1e1e2e; color: var(--color-text-muted); }
      .status-deprecated { background: #2d2305; color: var(--color-yellow); }
      .status-yanked { background: #2d0505; color: var(--color-red); }
      .search-container { position: relative; }
      .search-input {
        width: 100%;
        padding: 0.75rem 1rem;
        padding-right: 3.5rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 0.5rem;
        color: var(--color-text);
        font-size: 1rem;
        outline: none;
        transition: border-color 0.2s;
      }
      .search-input:focus { border-color: var(--color-accent); }
      .search-input::placeholder { color: var(--color-text-muted); }
      .search-shortcut {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        padding: 0.125rem 0.375rem;
        background: var(--color-border);
        border-radius: 0.25rem;
        font-size: 0.6875rem;
        color: var(--color-text-muted);
      }
      .permission-badge {
        display: flex;
        gap: 0.5rem;
        align-items: baseline;
        padding: 0.375rem 0.625rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 0.375rem;
        font-size: 0.8125rem;
      }
      .permission-capability { font-weight: 600; font-family: monospace; }
      .permission-scope { color: var(--color-text-muted); font-size: 0.75rem; }
      .permission-reason { color: var(--color-text-muted); font-size: 0.75rem; }
    </style>
  </head>
  <body>
    <nav>
      <div class="container">
        <a href="/" class="logo">⚡ FleetPrompt</a>
        <div class="nav-links">
          <a href="/">Search</a>
          <a href="/publishers">Publishers</a>
          <a href="/trust">Trust Dashboard</a>
        </div>
      </div>
    </nav>
    <main class="container">
      {@inner_content}
    </main>
  </body>
</html>
